# Beagle Fire Commands
gpioinfo			# get info of gpio pins
gpioset gpiochip2 10=1		# set pin 10 of gpio_out to 1

# Finding & Connecting with Serial
ls -l /dev/serial/by-id		# Find port, typically /dev/ttyACM1
tio /dev/ttyACM1		# Connect to port. User: beagle Pass: [], Ctrl+t & q to exit
minicom -D /dev/ttyACM1		# alt connection

# Libero Commands
libero &





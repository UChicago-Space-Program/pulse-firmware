set_io -port_name M2_UART_TXD  \
    -pin_name A7               \
    -fixed true                \
    -io_std LVCMOS33           \
    -DIRECTION OUTPUT

set_io -port_name M2_UART_RXD  \
    -pin_name H15              \
    -fixed true                \
    -io_std LVCMOS33           \
    -DIRECTION INPUT

